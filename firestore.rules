rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isAuth() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isDeveloper() {
      return isAuth() &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'developer';
    }

    // Deadline: 11:30 JST = 690 minutes since midnight JST
    function isBeforeDeadlineJST() {
      let jstMs = request.time.toMillis() + 9 * 60 * 60 * 1000;
      let minuteOfDay = int(jstMs / 60000) % 1440;
      return minuteOfDay < 690;
    }

    match /users/{userId} {
      allow read: if isAuth();
      allow create: if isAuth() &&
        request.auth.uid == userId &&
        request.resource.data.role == 'user';
      allow update: if isAdmin() ||
        (isAuth() && request.auth.uid == userId &&
         request.resource.data.diff(resource.data).affectedKeys().hasOnly(['name', 'journeyRouteId']));
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /eventParticipants/{participantId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /teams/{teamId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /config/{docId} {
      allow read: if isAuth();
      allow write: if isAdmin();
    }

    match /steps/{stepId} {
      allow read: if isAuth();
      allow create: if isAdmin() || isDeveloper() || (isAuth() &&
        request.auth.uid == request.resource.data.userId &&
        stepId == request.auth.uid + '_' + request.resource.data.date &&
        isBeforeDeadlineJST() &&
        request.resource.data.steps is int &&
        request.resource.data.steps > 0 &&
        request.resource.data.steps < 100000);
      allow update: if isAdmin() || isDeveloper() || (isAuth() &&
        request.auth.uid == resource.data.userId &&
        isBeforeDeadlineJST());
      allow delete: if isAdmin();
    }
  }
}
