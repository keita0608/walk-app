# ============================================================
# Supabase（必須）
# https://supabase.com でプロジェクトを作成してください
# ============================================================
NEXT_PUBLIC_SUPABASE_URL=https://xxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# ============================================================
# Google Fit OAuth（Android連携に必要）
# Google Cloud Console で作成してください
# https://console.cloud.google.com
# 1. プロジェクト作成
# 2. Fitness API を有効化
# 3. OAuth 同意画面を設定
# 4. OAuth 2.0 クライアントID を作成（ウェブアプリケーション）
# 5. 承認済みのリダイレクト URI に追加:
#    https://your-app.vercel.app/api/google-fit/callback
# ============================================================
GOOGLE_CLIENT_ID=xxxx.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-xxxx

# ============================================================
# アプリURL（本番環境のURL）
# ============================================================
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app
